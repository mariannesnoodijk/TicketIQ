# Kopieer dit bestand naar .env.local en vul de waarden in.
# .env.local wordt NIET gecommit (zie .gitignore).

# Supabase (Deelopdracht 2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI provider voor de Vercel AI SDK (Deelopdracht 1)
