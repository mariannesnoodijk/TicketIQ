# Kopieer dit bestand naar .env.local en vul de waarden in.
# .env.local wordt NIET gecommit (zie .gitignore).

# Supabase (Deelopdracht 2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optioneel: gebruikt voor auth callback-redirects (lokaal en productie)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# DummyJSON Custom Response API — supporttickets (Deelopdracht 1 / PR4)
NEXT_PUBLIC_DUMMYJSON_TICKETS_URL=https://dummyjson.com/c/1d10-7105-4edb-a0b1

# AI provider voor de Vercel AI SDK (Deelopdracht 1)
# Bijvoorbeeld een OpenAI-sleutel; pas aan naar de provider die je gebruikt.
OPENAI_API_KEY=

# --- Optioneel: AI-tokenlimieten (defaults zijn streng getuned) ---
# Max tickets per fetchTickets-toolcall (ook bij fetchAll)
# AI_MAX_TICKETS_PER_FETCH=50
# Comma-gescheiden analyse-opties in de UI (geen "alle tickets")
# AI_ANALYZE_TICKET_LIMITS=25,50
# Standaard geselecteerde analyse-limiet (moet in AI_ANALYZE_TICKET_LIMITS staan)
# AI_DEFAULT_ANALYZE_LIMIT=50
# Max agent/LLM-stappen per analyse-run
# AI_MAX_AGENT_STEPS=8
# Max chatberichten naar het model + max tekens per gebruikersbericht
# AI_MAX_CHAT_MESSAGES=24
# AI_MAX_USER_MESSAGE_CHARS=2000
# Max output-tokens per agent-stap / revise-call
# AI_MAX_AGENT_OUTPUT_TOKENS=4096
# AI_MAX_REVISE_OUTPUT_TOKENS=3000
# Rate limits per ingelogde gebruiker per uur
# AI_AGENT_REQUESTS_PER_HOUR=15
# AI_REVISE_REQUESTS_PER_HOUR=15
