# Kopieer dit bestand naar .env.local en vul de waarden in.
# .env.local wordt NIET gecommit (zie .gitignore).

# Supabase (Deelopdracht 2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optioneel: gebruikt voor auth callback-redirects (lokaal en productie)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI provider voor de Vercel AI SDK (Deelopdracht 1)
# Bijvoorbeeld een OpenAI-sleutel; pas aan naar de provider die je gebruikt.
OPENAI_API_KEY=
